<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TicketManager.View.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketManager.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="20" Margin="0,0,0,30">
            <TextBlock Text="Find your next flight" FontSize="28" FontWeight="Bold" Foreground="#2bb8c0"/>

            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom">

                <TextBox Header="Location" PlaceholderText="e.g. Barcelona..." Width="200" Foreground="Black"/>

                <StackPanel>
                    <TextBlock Text="Flight Type" Foreground="Black" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <RadioButton Content="Departure" IsChecked="True" Foreground="Black"/>
                        <RadioButton Content="Arrival" Foreground="Black"/>
                    </StackPanel>
                </StackPanel>

                <CalendarDatePicker Header="Date" PlaceholderText="Select date" Width="150" Foreground="Black"/>

                <TextBox Header="Passengers" PlaceholderText="Nr" Width="80" Foreground="Black"/>

                <Button Content="SEARCH" 
                        Background="#2bb8c0" Foreground="White" 
                        FontWeight="Bold" Height="32" 
                        VerticalAlignment="Bottom" Margin="0,0,0,1"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Available Flights" FontSize="20" FontWeight="SemiBold" Foreground="Black" Margin="0,0,0,10"/>

            <ListView x:Name="AvailableFlightsGrid" Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" SelectionMode="Single">

                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Background="#f4f4f4" Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Flight Nr" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Grid.Column="1" Text="Route" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Grid.Column="2" Text="Date &amp; Time" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Grid.Column="3" Text="Price" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Grid.Column="4" Text="Action" FontWeight="Bold" Foreground="Black"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding FlightNr}" VerticalAlignment="Center" Foreground="Black"/>
                            <TextBlock Grid.Column="1" Text="{Binding RouteName}" VerticalAlignment="Center" Foreground="Black"/>
                            <TextBlock Grid.Column="2" Text="{Binding Date}" VerticalAlignment="Center" Foreground="Black"/>
                            <TextBlock Grid.Column="3" Text="{Binding Price}" VerticalAlignment="Center" Foreground="Black"/>

                            <Button Grid.Column="4" Content="Book" Background="#2bb8c0" Foreground="White" CornerRadius="4" Height="30"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
