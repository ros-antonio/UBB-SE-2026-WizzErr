<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TicketManager.View.BookingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketManager.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Complete Your Booking" FontSize="28" FontWeight="Bold" Foreground="#2bb8c0" Margin="0,0,0,20"/>

        <!-- Passengers List -->
        <Border Grid.Row="1" BorderBrush="#2bb8c0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Passengers" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <ItemsControl x:Name="passengersItemsControl">
                    <!-- Passenger details bindings will go here -->
                </ItemsControl>
                <Button x:Name="addPassengerButton" Content="+ Add Passenger" Background="Transparent" Foreground="#2bb8c0" BorderBrush="#2bb8c0" BorderThickness="1" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Seat Map -->
        <Border Grid.Row="2" BorderBrush="#2bb8c0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Seat Selection" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid x:Name="seatMapGrid">
                    <!-- Seat Map logic will be rendered here -->
                    <TextBlock Text="Seat map placeholder..." Foreground="Gray" FontStyle="Italic"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Confirmation -->
        <Button x:Name="confirmationButton" Grid.Row="3" Content="Confirm Booking" Background="#2bb8c0" Foreground="White" FontWeight="Bold" Height="40" HorizontalAlignment="Right" Width="200" CornerRadius="8"/>
    </Grid>
</Page>