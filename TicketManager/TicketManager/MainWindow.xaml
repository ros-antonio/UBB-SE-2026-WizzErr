<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TicketManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TicketManager">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

	<Grid Background="Transparent" RequestedTheme="Light">

		<NavigationView x:Name="TopNav"
						PaneDisplayMode="Top"
						IsBackButtonVisible="Visible"
						ItemInvoked="TopNav_ItemInvoked"
						BackRequested="TopNav_BackRequested">

			<NavigationView.Resources>
				<SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#2bb8c0" />
				<SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="#2bb8c0" />
				<SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="#2bb8c0" />
				<SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#2bb8c0" />
			</NavigationView.Resources>

			<NavigationView.MenuItems>
				<NavigationViewItem Content="Search" Tag="TicketManager.View.FlightSearchPage" />
				<NavigationViewItem Content="Dashboard" Tag="TicketManager.View.DashboardPage" />
				<NavigationViewItem Content="Memberships" Tag="TicketManager.View.MembershipsPage" />
				<NavigationViewItem Content="Services" Tag="TicketManager.View.ServicesPage" />
				<NavigationViewItem Content="Support" Tag="TicketManager.View.SupportPage" />
			</NavigationView.MenuItems>

			<Frame x:Name="ContentFrame" />

		</NavigationView>

    </Grid>
</Window>
